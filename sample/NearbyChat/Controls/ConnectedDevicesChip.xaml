<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="NearbyChat.Controls.ConnectedDevicesChip"
    x:Name="this">
    <Border
        Background="{StaticResource AccentConnections}"
        StrokeShape="RoundRectangle 30"
        Stroke="#00702222"
        Padding="15,6"
        IsVisible="{Binding Count, Source={x:Reference this}, Converter={StaticResource intToBoolConverter}}">
        <Border.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding Command, Source={x:Reference this}}"/>
        </Border.GestureRecognizers>
        <HorizontalStackLayout Spacing="8"
                               VerticalOptions="Center">
            <Image WidthRequest="25"
                   HeightRequest="25"
                   VerticalOptions="Center">
                <Image.Source>
                    <FontImageSource
                        FontFamily="NearbyChatIcons"
                        Glyph="{StaticResource icon-users}"
                        Color="White"/>
                </Image.Source>
            </Image>
            <Label
                Text="{Binding Count, Source={x:Reference this}}"
                TextColor="White"
                FontSize="18"
                FontAttributes="Bold"
                VerticalOptions="Center"/>
        </HorizontalStackLayout>
    </Border>
</ContentView>
